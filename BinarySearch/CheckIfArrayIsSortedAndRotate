# include<iostream>
# include<bits/stdc++.h>
using namespace std;
class Solution{
    public:
    int search(vector<int>&nums){
        int count=0;
        for(int i=0;i<nums.size()-1;i++){
            if(nums[i]>nums[i+1]){
                count++;
            }
        }
        return count;
    }

};
// Time complexity:-O(n) 
// Space complexity:-O(1) for count variable
