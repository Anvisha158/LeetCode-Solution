using namespace std;
// brute force approach
class Solution{
    public:
    int countPositiveNegative(vector<int> & nums){
        int pos=0;
        int neg=0;
        for(int i=0;i<nums.size();i++){
            if(nums[i]>0){
                pos++;
            }
            else if(nums[i]<0){
                neg++;
            }
        }
        return max(pos,neg);
    }
};
// time complexity:- O(n)
// space complexity"- O(1)
