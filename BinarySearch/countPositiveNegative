using namespace std;
// brute force approach
class Solution{
    public:
    int countPositiveNegative(vector<int> & nums){
        int pos=0;
        int neg=0;
        for(int i=0;i<nums.size();i++){
            if(nums[i]>0){
                pos++;
            }
            else if(nums[i]<0){
                neg++;
            }
        }
        return max(pos,neg);
    }
};
// time complexity:- O(n)
// space complexity"- O(1)
// optimal approach
// use binary search 
class Solution {
public:
    int maximumCount(vector<int>& nums) {

        int n = nums.size();

        // first >= 0
        int low = 0, high = n - 1;
        int firstNonNegative = n;

        while(low <= high) {

            int mid = low + (high - low) / 2;

            if(nums[mid] >= 0) {
                firstNonNegative = mid;
                high = mid - 1;
            }
            else {
                low = mid + 1;
            }
        }

        int neg = firstNonNegative;

        // first > 0
        low = 0;
        high = n - 1;

        int firstPositive = n;

        while(low <= high) {

            int mid = low + (high - low) / 2;

            if(nums[mid] > 0) {
                firstPositive = mid;
                high = mid - 1;
            }
            else {
                low = mid + 1;
            }
        }

        int pos = n - firstPositive;

        return max(pos, neg);
    }
};
// time complexity:- O(log n)
// space complexity:- O(1)
